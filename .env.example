# --- Frontier API keys (leave blank to disable a provider) ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=

# --- Host network exposure ---
# Synapse has no authentication, so the web UI is loopback-only by default.
# Set this to 0.0.0.0 only when you intentionally want LAN access.
SYNAPSE_BIND_ADDRESS=127.0.0.1
# Used only with docker-compose.dev.yml for Vite's local /api proxy.
SYNAPSE_API_BIND_ADDRESS=127.0.0.1
# URL projects reject loopback/private-network literals by default (SSRF guard).
ALLOW_PRIVATE_URLS=false

# --- Data protection ---
# Use long, random secrets and keep them available for the lifetime of the data.
# BACKUP_ENCRYPTION_KEY encrypts new backup archives; blank means unencrypted.
BACKUP_ENCRYPTION_KEY=
# SETTINGS_ENCRYPTION_KEY protects stored cloud and GitHub credentials. If blank, Synapse
# creates data/db/.settings.key; changing or losing either key loses access.
SETTINGS_ENCRYPTION_KEY=

# --- Local model serving ---
# Default points at the bundled Ollama container. Repository analysis requires
# this service, localhost, or another loopback endpoint; non-repository public
# material may still use a remote Ollama endpoint when configured separately.
OLLAMA_BASE_URL=http://ollama:11434
# Repository analysis uses long grounded prompts. Synapse floors its own
# repository requests at a 64k context window; this keeps the bundled Ollama
# server's default window aligned for anything else that talks to it directly.
OLLAMA_CONTEXT_LENGTH=65536
# Any OpenAI-compatible server (LM Studio, llama.cpp, vLLM, LocalAI, Jan, …)
# for steps assigned to the openai_compat provider. Include the /v1 suffix.
# From inside Docker, reach an app running on this host via host.docker.internal
# — LM Studio's default server would be: http://host.docker.internal:1234/v1
OPENAI_COMPAT_BASE_URL=
# Only needed if that server enforces a key (vLLM --api-key, a proxy, …).
OPENAI_COMPAT_API_KEY=

# --- Host media directory mounted read-only into the app at /host-media ---
# Local-file inputs are given as paths relative to this directory.
HOST_MEDIA_DIR=./data/media
# Browser uploads are streamed to data/media; default is 20 GiB.
MAX_UPLOAD_BYTES=21474836480

# --- Research-paper extraction ---
# CPU threads used by the concurrency-one offline Docling/Tesseract worker.
# PDF admission defaults are 250 MiB, 500 pages, and 5 million extracted chars.
PAPER_WORKER_THREADS=4

# --- GitHub repository analysis ---
# Private repository credentials are entered in Settings and encrypted at rest;
# they are never copied into this file. Repository snapshots are retained under
# the fixed, isolated data/repositories mount so citations and local-only Q&A
# remain reproducible without overlapping the vault, media, or backup trees.
