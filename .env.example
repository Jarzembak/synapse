# --- Frontier API keys (leave blank to disable a provider) ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=

# --- Local model serving ---
# Default points at the bundled ollama container. Point at a remote GPU box
# (e.g. http://10.0.0.5:11434) to use bigger local models with zero code change.
OLLAMA_BASE_URL=http://ollama:11434

# --- Host media directory mounted read-only into the app at /host-media ---
# Local-file inputs are given as paths relative to this directory.
HOST_MEDIA_DIR=./data/media
